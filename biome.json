{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "files": {
    "includes": [
      "**",
      "!node_modules",
      "!dist",
      "!worktrees",
      "!apps/**/dist",
      "!apps/**/node_modules",
      "!packages/contracts/out",
      "!packages/contracts/lib",
      "!packages/contracts/cache",
      "!packages/contracts/broadcast"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 88
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noArrayIndexKey": "off"
      }
    }
  }
}
